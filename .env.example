# ─── LangPerf .env.example ─────────────────────────────────────────────
# Copy to .env (project root) and fill in real values. Docker Compose
# reads the root .env automatically. Nothing here is a real credential —
# replace placeholders before using anywhere that matters.

# ─── API (langperf-api) ────────────────────────────────────────────────
# Async SQLAlchemy connection string. The docker-compose Postgres service
# uses the credentials below; for a bare Python process, point at your
# own DB (e.g. sqlite+aiosqlite:///local.db). Also consumed by Alembic.
DATABASE_URL=postgresql+asyncpg://langperf:langperf@postgres:5432/langperf

# Server log verbosity: DEBUG | INFO | WARNING | ERROR. Default INFO.
LANGPERF_LOG_LEVEL=INFO

# Comma-separated CORS origins for the web client. Defaults to the
# standard local dev origin if unset.
LANGPERF_CORS_ORIGINS=http://localhost:3030

# ─── Web (langperf-web) ────────────────────────────────────────────────
# Server-side base URL — used by Next server components. Inside the
# docker network this is the service name; on a host-run Next dev
# server, point at http://localhost:4318.
LANGPERF_API_URL=http://langperf-api:4318

# Client-side base URL, exposed to the browser at build time. Must be
# reachable from the user's browser (so use the host-mapped port).
NEXT_PUBLIC_LANGPERF_API_URL=http://localhost:4318

# ─── Postgres (docker-compose service) ─────────────────────────────────
# These feed the `postgres` service in docker-compose.yml. They must
# agree with the credentials embedded in DATABASE_URL above.
POSTGRES_USER=langperf
POSTGRES_PASSWORD=langperf
POSTGRES_DB=langperf

# ─── SDK (langperf Python package, read in your agent process) ─────────
# These are NOT read by the server — they live in the environment of
# whatever Python process calls langperf.init(). Listed here so new
# contributors know the full surface.

# Required. Minted per-agent in the UI (Agents → + Add agent).
LANGPERF_API_TOKEN=lp_your_token_here

# OTLP endpoint the SDK exports to. Default http://localhost:4318.
LANGPERF_ENDPOINT=http://localhost:4318

# Agent name shown in the UI. Falls back to the agent_name kwarg on
# langperf.init(). NOTE: the current tracer reads LANGPERF_SERVICE_NAME
# (below); LANGPERF_AGENT_NAME is documented in the README but not yet
# wired up — prefer passing agent_name= or setting SERVICE_NAME for now.
# LANGPERF_AGENT_NAME=my-agent

# Legacy name for the agent. Still the one the SDK actually reads today.
LANGPERF_SERVICE_NAME=my-agent

# Maps to OTel deployment.environment. Conventionally dev | staging | prod.
LANGPERF_ENVIRONMENT=dev

# Free-form version string displayed in the UI.
LANGPERF_VERSION=0.1.0

# ─── Examples / smoke scripts (scripts/smoke.py, examples/*) ───────────
# Optional. Only read by the demo scripts that talk to a local
# OpenAI-compatible backend (LM Studio by default). Not needed for
# running the stack itself.
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# SMOKE_MODEL=local-model

# ─── Tests (web Playwright harness) ────────────────────────────────────
# Override if your dev stack isn't on the default port.
# LANGPERF_API_BASE=http://localhost:4318
